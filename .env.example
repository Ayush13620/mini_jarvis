OPENAI_API_KEY=
HOST=0.0.0.0
PORT=5000
SAMPLE_RATE=16000
VOICE=alloy
STT_PROVIDER=local
TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
WHISPER_MODEL=small.en
WHISPER_COMPUTE_TYPE=int8
WHISPER_DEVICE=cpu
CHAT_MODEL=gpt-4.1-mini
USE_OLLAMA_CHAT=true
OLLAMA_MODEL=qwen2.5:3b-instruct
OLLAMA_URL=http://127.0.0.1:11434/api/chat
TTS_PROVIDER=local
TTS_MODEL=gpt-4o-mini-tts
ENERGY_THRESHOLD=280
MIN_SPEECH_MS=350
SILENCE_HOLD_MS=900
MAX_SPEECH_MS=10000
PRE_ROLL_MS=250
ADAPTIVE_VAD=true
NOISE_FLOOR_ALPHA=0.02
VAD_MULTIPLIER=3.2
RESPONSE_COOLDOWN_MS=600
AUDIO_DEBUG=true
DEBUG_EVERY_MS=1200
PCM_INT32_GAIN_DIV=4
ENABLE_DCBLOCK=true
DCBLOCK_R=0.995
REQUIRE_WAKE_WORD=false
WAKE_WORD=jarvis
WAKE_ALIASES=
ASYNC_TTS=false
BARGE_IN=false
AUTH_TOKEN=

IGNORE_SHORT_TRANSCRIPTS=true
MIN_TRANSCRIPT_CHARS=4
