# Mini Jarvis — Environment Configuration
# Copy this file to .env and adjust values for your setup.
# Lines starting with # are comments and are ignored.

# ── Network ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=5000

# Optional shared secret.  ESP32 must send "AUTH <token>\n" as first line.
# Leave empty to disable auth (fine for a trusted home network).
AUTH_TOKEN=

# ── Audio input ────────────────────────────────────────────────────────────────
SAMPLE_RATE=16000

# ESP32 sends centered 12-bit ADC samples packed as int32.
# Keep this at 1 unless the signal is clipping after custom firmware changes.
PCM_INT32_GAIN_DIV=1

# DC-blocking IIR filter removes ADC bias and low-frequency hum.
ENABLE_DCBLOCK=true
# Pole position (0 < R < 1).  Closer to 1 = sharper high-pass / more bass cut.
DCBLOCK_R=0.995

# ── VAD (Voice Activity Detection) ─────────────────────────────────────────────
# Fixed energy threshold (mean absolute value of int16 samples).
# Adaptive mode adjusts on top of this floor.
ENERGY_THRESHOLD=280

# Ignore segments shorter than this — filters out click / pop events.
MIN_SPEECH_MS=350

# How long silence must last before the turn is considered finished.
SILENCE_HOLD_MS=900

# Hard cap — force-flush a segment after this many ms regardless of silence.
MAX_SPEECH_MS=10000

# Audio captured just before voice onset is prepended to the segment.
PRE_ROLL_MS=250

# Adaptive VAD: tracks background noise floor and scales the threshold.
ADAPTIVE_VAD=true
# Smoothing coefficient for noise floor tracker (smaller = slower adaptation).
NOISE_FLOOR_ALPHA=0.02
# Threshold = noise_floor × VAD_MULTIPLIER  (or ENERGY_THRESHOLD, whichever is larger).
VAD_MULTIPLIER=3.2

# Minimum gap between assistant replies — prevents double-triggers.
RESPONSE_COOLDOWN_MS=600

# ── Wake word ──────────────────────────────────────────────────────────────────
WAKE_WORD=jarvis

# Set to true to require the wake word before every query.
REQUIRE_WAKE_WORD=false

# Comma-separated alternative spellings Whisper might produce (e.g. "jarvis,jarvas").
WAKE_ALIASES=

# ── STT (Speech-to-Text) ───────────────────────────────────────────────────────
# Options:
#   local  → faster-whisper on-device (recommended, no API key needed)
#   openai → OpenAI Whisper API         (requires OPENAI_API_KEY below)
STT_PROVIDER=local

# faster-whisper model size.  Smaller = faster but less accurate.
# Recommended for i3/integrated-GPU: small.en
# Options: tiny.en  small.en  medium.en  large-v3
WHISPER_MODEL=small.en

# Quantisation.  int8 is fastest on CPU; float16 requires a dedicated GPU.
WHISPER_COMPUTE_TYPE=int8
WHISPER_DEVICE=cpu

# Only used when STT_PROVIDER=openai
TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# ── Chat ───────────────────────────────────────────────────────────────────────
# true  → Ollama local LLM (no API key, recommended)
# false → OpenAI Chat API  (requires OPENAI_API_KEY below)
USE_OLLAMA_CHAT=true

# Qwen3.5 does not have an exact 1B local Ollama tag; 0.8B is the closest
# latest small target, with 2B available if your laptop can spare more RAM.
OLLAMA_MODEL=qwen3.5:0.8b
OLLAMA_URL=http://127.0.0.1:11434/api/chat

# Only used when USE_OLLAMA_CHAT=false
CHAT_MODEL=gpt-4.1-mini

# ── TTS (Text-to-Speech) ───────────────────────────────────────────────────────
# Options:
#   local  → pyttsx3 offline synthesis (no API key needed)
#   openai → OpenAI TTS API            (requires OPENAI_API_KEY below)
TTS_PROVIDER=local

# Speak in a background thread so VAD keeps listening during playback.
ASYNC_TTS=true

# Allow a new voice segment to interrupt ongoing TTS playback.
BARGE_IN=true

# Only used when TTS_PROVIDER=openai
TTS_MODEL=gpt-4o-mini-tts
VOICE=alloy

# ── Transcript filtering ───────────────────────────────────────────────────────
# Drop transcripts that are too short to be real speech (e.g. mic pops).
IGNORE_SHORT_TRANSCRIPTS=true
MIN_TRANSCRIPT_CHARS=4

# ── Debug ──────────────────────────────────────────────────────────────────────
AUDIO_DEBUG=true
DEBUG_EVERY_MS=1500

# ── OpenAI (only required when STT_PROVIDER / TTS_PROVIDER / chat is "openai") ─
# OPENAI_API_KEY=sk-...
